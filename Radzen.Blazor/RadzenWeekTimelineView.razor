@using Radzen.Blazor
@using Radzen.Blazor.Rendering

@inherits SchedulerViewBase

@code {
    public override RenderFragment Render()
    {
        var appointments = Scheduler?.GetAppointmentsInRange(StartDate, EndDate).ToList() ?? new List<AppointmentData>();

        return
    @<CascadingValue Value=@Scheduler>
        <WeekTimelineView StartDate=@StartDate EndDate=@EndDate Appointments=@appointments
            HeaderFormat=@HeaderFormat
            Resources=@Resources ResourceProperty=@ResourceProperty ResourceTextProperty=@ResourceTextProperty ResourceValueProperty=@ResourceValueProperty GroupOrientation=@GroupOrientation
            AppointmentMove=OnAppointmentMove />
    </CascadingValue>
    ;
    }
}
